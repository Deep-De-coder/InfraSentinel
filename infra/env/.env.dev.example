# InfraSentinel DEV mode — Claude + mock CV, no NetBox required
# Copy to infra/env/.env.dev (done automatically by scripts/dev/create_env_dev.sh)
# Usage: docker compose -f infra/docker-compose.yml --env-file infra/env/.env.dev up -d --build

INFRASENTINEL_MODE=mock
CV_MODE=mock
NETBOX_MODE=mock
EVIDENCE_BACKEND=local

# --- Claude / LLM ---
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# API auth (fill in or let create_env_dev.sh generate)
INFRA_API_KEY=
MCP_API_KEY=
AUTH_READS=false

# Temporal
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_TASK_QUEUE=infrasentinel-task-queue

# Database
DATABASE_URL=postgresql+asyncpg://infrasentinel:infrasentinel@app-postgres:5432/infrasentinel

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=infrasentinel-evidence

# NetBox (not used in this mode; kept for completeness)
NETBOX_URL=http://netbox:8080
NETBOX_TOKEN=

# A2A
A2A_MODE=off
A2A_MOP_URL=http://a2a-mop-agent:8091
A2A_VISION_URL=http://a2a-vision-agent:8092
A2A_CMDB_URL=http://a2a-cmdb-agent:8093
